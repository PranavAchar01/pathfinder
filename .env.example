# Copy to backend/.env (or export). Everything defaults to "mock" so the app runs
# locally with no GPU and no keys. Flip to runpod/local when ready.

# --- Backends: mock | local | runpod ---
PATHFINDER_PERCEPTION_BACKEND=mock
PATHFINDER_REASONING_BACKEND=mock

# --- RunPod: Qwen (vLLM, OpenAI-compatible) ---
PATHFINDER_RUNPOD_API_KEY=
PATHFINDER_RUNPOD_QWEN_BASE_URL=https://api.runpod.ai/v2/<endpoint-id>/openai/v1
PATHFINDER_RUNPOD_QWEN_MODEL=Qwen/Qwen2.5-0.5B-Instruct

# --- RunPod: perception endpoint (YOLO + depth + RSI fine-tune) ---
PATHFINDER_RUNPOD_PERCEPTION_URL=

# --- Bright Data: web identification of unknown objects + training-data harvest ---
PATHFINDER_BRIGHTDATA_API_KEY=
PATHFINDER_BRIGHTDATA_SERP_ZONE=serp
PATHFINDER_BRIGHTDATA_UNLOCKER_ZONE=unlocker

# --- Collision thresholds (meters) ---
PATHFINDER_COLLISION_WARN_M=2.0
PATHFINDER_COLLISION_STOP_M=1.0

# --- RSI ---
PATHFINDER_RSI_ENABLED=true
PATHFINDER_RSI_REVIEW_EVERY=50
PATHFINDER_RSI_MIN_CONFIDENCE=0.45

# --- Local weights (only when *_BACKEND=local) ---
PATHFINDER_YOLO_WEIGHTS=yolov8n.pt
PATHFINDER_DEPTH_MODEL=depth-anything/Depth-Anything-V2-Small-hf
