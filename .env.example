# Copy to backend/.env. The app runs with NO keys: the edge falls back to mock detection
# and a mock LLM, and Bright Data returns a stub. Fill these in to go fully live.

# Edge LLM (WebLLM model id, runs in the browser via WebGPU).
PATHFINDER_LLM_MODEL=Qwen2.5-0.5B-Instruct-q4f16_1-MLC

# RunPod GPU — RSI training only (no LLM, no per-frame inference).
PATHFINDER_RUNPOD_API_KEY=
PATHFINDER_RSI_TRAINER_URL=

# Bright Data — web identification of unknown objects + RSI training-data harvest.
PATHFINDER_BRIGHTDATA_API_KEY=
PATHFINDER_BRIGHTDATA_SERP_ZONE=serp
PATHFINDER_BRIGHTDATA_UNLOCKER_ZONE=unlocker

# Collision thresholds (meters), served to the edge.
PATHFINDER_COLLISION_WARN_M=2.0
PATHFINDER_COLLISION_STOP_M=1.0

# RSI.
PATHFINDER_RSI_ENABLED=true
PATHFINDER_RSI_REVIEW_EVERY=50
PATHFINDER_RSI_MIN_CONFIDENCE=0.45
